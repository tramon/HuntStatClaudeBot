# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=

# Bot username WITHOUT the @ sign
BOT_USERNAME=HuntStatClaudeBot

# ── Security ───────────────────────────────────────────────────────────────
# Your group's chat ID (negative number, e.g. -1001234567890)
# Leave empty on first run — bot will log the chat ID when added to a group
ALLOWED_CHAT_IDS=

# Your personal Telegram user ID — find it via @userinfobot
OWNER_USER_ID=

# ── Anthropic ──────────────────────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Claude model (haiku = fast & cheap, sonnet = smarter)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Claude memory ──────────────────────────────────────────────────────────
# true  = Claude sees recent chat messages (has memory)
# false = Claude answers only the current question (cheaper)
CLAUDE_MEMORY=false
CONTEXT_MESSAGES=15

# ── Google Sheets ──────────────────────────────────────────────────────────
# Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=

# Path to service account JSON key file (local development)
GOOGLE_CREDENTIALS_FILE=huntstatbot.json

# For Render/CI: paste the entire JSON content of the credentials file here
GOOGLE_CREDENTIALS_JSON=
